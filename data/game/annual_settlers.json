{
  "id": "annual_settlers",
  "version": "0.9.35",
  "description": "ระบบผู้มาตั้งถิ่นฐานประจำปีที่เพิ่มคนตามความสามารถรองรับจริงของชุมชน แยกจากเหตุการณ์ผู้อพยพสุ่ม",
  "timing": "ประเมินเมื่อขึ้นปีใหม่หลังเดือน 12",
  "constraints": {
    "canBeZero": true,
    "usesStage": true,
    "usesSpareShelter": true,
    "usesFoodReserve": true,
    "usesSettlementAttractiveness": true,
    "neverForcesInfluxWithoutCapacity": true
  },
  "effects": {
    "addsNamedPeople": true,
    "firstNightFoodCostPerPerson": 1,
    "firstNightWaterCostPerPerson": 0.7,
    "morale": "เพิ่มเล็กน้อยเมื่อรับคนใหม่ได้อย่างมั่นคง",
    "trust": "อาจลดลงเมื่อรับคนมากกว่าทรัพยากรที่รองรับ",
    "health": "อาจลดลงเมื่อที่พักหรือเสบียงไม่พอ",
    "reportReasonWhenZero": true
  },
  "godotPorting": {
    "suggestedSystem": "AnnualPopulationFlow",
    "input": [
      "year",
      "stage",
      "shelterCapacity",
      "currentPopulation",
      "foodReserve",
      "settlementAttractiveness"
    ],
    "output": [
      "newPeople[]",
      "resourceDelta",
      "notice",
      "chronicleLog"
    ]
  }
}
